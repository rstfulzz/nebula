{
  "name": "nebula",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "A Mantle-native, policy-aware AI treasury assistant",
  "repository": "github.com/rstfulzz/nebula",
  "license": "MIT",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "build": "bun run --filter='*' build",
    "typecheck": "tsc -b",
    "test": "bun test --timeout 30000 packages/*/src",
    "smoke": "bun test/smoke-live.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "fix": "biome check --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish",
    "nebula": "bun packages/cli/bin/nebula",
    "test:cache": "bun test/local/prompt-cache.test.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.10",
    "@types/bun": "^1.1.14",
    "@types/node": "^22.10.2",
    "nebula-ai-core": "workspace:*",
    "nebula-ai-plugin-telegram": "workspace:*",
    "@opentui/core": "^0.1.97",
    "@opentui/solid": "^0.1.97",
    "ethers": "^6.13.0",
    "solid-js": "^1.9.12",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "agent-browser": "^0.26.0"
  },
  "overrides": {
    "viem": "2.48.11"
  }
}

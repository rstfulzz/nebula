{
  "name": "nebula-ai-core",
  "version": "0.4.0",
  "type": "module",
  "description": "The SDK for nebula, a Casper-native policy-aware AI treasury agent: brain, local memory + storage, the policy/approval engine, Casper account identity, and the on-chain registry client",
  "license": "MIT",
  "homepage": "https://github.com/rstfulzz/nebula",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rstfulzz/nebula.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/rstfulzz/nebula/issues"
  },
  "keywords": ["nebula", "ai", "agent", "casper", "cspr", "treasury", "policy"],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.1"
  },
  "files": ["src", "!src/**/*.test.ts", "README.md"],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config.ts",
    "./events": "./src/events/index.ts",
    "./memory": "./src/memory/index.ts",
    "./tools": "./src/tools/index.ts",
    "./brain": "./src/brain/index.ts",
    "./storage": "./src/storage/index.ts",
    "./wallet": "./src/wallet/index.ts",
    "./identity": "./src/identity/index.ts",
    "./runtime": "./src/runtime/index.ts",
    "./paths": "./src/paths.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "bun test"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "casper-js-sdk": "5.0.12",
    "gray-matter": "^4.0.3",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/qrcode-terminal": "^0.12.2"
  }
}

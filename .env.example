# Copy to .env and fill in. NEVER commit real secrets — .env is gitignored.
# This is the canonical list of every env var Nebula reads.

# ─── LLM brain (OpenAI-compatible) ───────────────────────────────────────────
# Default model is gpt-4o-mini. Point BASE_URL/MODEL at any OpenAI-compatible
# gateway (Z.AI GLM, Tencent Hunyuan, etc.) to switch providers with no code change.
OPENAI_API_KEY=
# NEBULA_LLM_API_KEY=           # alternative to OPENAI_API_KEY
# NEBULA_LLM_BASE_URL=          # e.g. https://api.z.ai/v1  (omit for OpenAI default)
# NEBULA_LLM_MODEL=gpt-4o-mini

# ─── Casper network (migration target — see knowledge-casper/) ───────────────
# Buildathon deploys to Casper Testnet. CSPR.cloud gives managed RPC + REST +
# streaming and powers the Casper MCP server (.mcp.json). Get a free key at
# https://console.cspr.build  ->  set CSPR_CLOUD_API_KEY before launching Claude.
CSPR_CLOUD_API_KEY=
CASPER_CHAIN_NAME=casper-test
CASPER_NODE_RPC=https://node.testnet.cspr.cloud/rpc
# Deployer/agent wallet (TESTNET ONLY — see knowledge-casper/reference/wallet.md).
# Point this at the secret key OUTSIDE the repo; never paste the key or mnemonic here.
CASPER_SECRET_KEY_PATH=
# Odra livenet deploys reuse the same secret key + node:
# ODRA_CASPER_LIVENET_SECRET_KEY_PATH=${CASPER_SECRET_KEY_PATH}
# ODRA_CASPER_LIVENET_NODE_ADDRESS=${CASPER_NODE_RPC}
# ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test

# ─── Mantle network (LEGACY — being migrated to Casper) ──────────────────────
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_CHAIN_ID=5000

# ─── Fund-control policy (deterministic; optional but recommended) ───────────
# NEBULA_POLICY_MAX_NATIVE_MNT=2.0        # hard cap: block native sends over 2 MNT
# NEBULA_POLICY_AUTO_MAX_NATIVE_MNT=0.1   # auto up to 0.1 MNT; above -> require approval
# NEBULA_POLICY_MAX_SLIPPAGE_BPS=100      # block swaps over 1% slippage
# NEBULA_POLICY_AUTONOMY=auto             # auto | confirm | readonly
# NEBULA_POLICY_TOKEN_ALLOWLIST=0x...,0x...
# NEBULA_POLICY_RECIPIENT_ALLOWLIST=0x...,0x...
# NEBULA_POLICY_READONLY=1                # reject all writes

# ─── Nansen (counterparty intel — powers nansen.labels) ──────────────────────
# Read-only address-label API; endpoints are credit-metered.
NANSEN_API_KEY=

# ─── Bybit (read-only portfolio — powers cex.balance) ────────────────────────
# Use a ROTATED, READ-ONLY, IP-allowlisted key. Trading/withdrawal stay disabled;
# Nebula never trades on the CEX (that would bypass the on-chain safety pipeline).
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ─── Telegram bot channel (optional) ─────────────────────────────────────────
# When TELEGRAM_BOT_TOKEN is set, `nebula chat` brings the bot online directly
# from env (no `nebula telegram setup` needed). TELEGRAM_CHAT_ID is the allowed
# user id (DMs from other users are ignored); leave blank for open access.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_USERNAME=

# ─── Signers (use a secret manager in production; never commit) ──────────────
# Agent signer override — the agent normally generates its own encrypted
# keystore at `nebula init`; set this only to pin a specific key.
NEBULA_SIGNER_PRIVATE_KEY=
# NEBULA_OPERATOR_PRIVKEY=      # operator wallet for non-interactive flows
# NEBULA_AGENT_PRIVKEY_HEX=     # agent EOA privkey for headless gateway boots

# ─── WalletConnect / Reown (public projectId; not a secret) ──────────────────
# NEBULA_WC_PROJECT_ID=974ed7663d88e07086104fa9a73b2d87

# ─── Execution sandbox (defense-in-depth beneath the permission floor) ───────
# NEBULA_SANDBOX_MODE=none      # none | os | docker  (overrides config.sandbox.mode)
# NEBULA_BROWSER_CDP_URL=       # attach browser.* tools to an existing Chrome DevTools endpoint

# ─── Web console (apps/web — Next.js; put these in apps/web/.env.local) ───────
# SESSION_SECRET signs the SIWE (Sign-In With Ethereum) session cookie. Must be
# at least 32 chars. Generate one with:  openssl rand -hex 32
SESSION_SECRET=
# NEXT_PUBLIC_WC_PROJECT_ID=974ed7663d88e07086104fa9a73b2d87

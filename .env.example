# Copy to .env and fill in. NEVER commit real secrets — .env is gitignored.

# --- LLM brain (OpenAI-compatible) ---
# Default model is gpt-4o-mini. Point BASE_URL/MODEL at any OpenAI-compatible
# gateway (e.g. Z.AI GLM, Tencent Hunyuan) to switch providers with no code change.
OPENAI_API_KEY=
# NEBULA_LLM_API_KEY=          # alternative to OPENAI_API_KEY
# NEBULA_LLM_BASE_URL=         # e.g. https://api.z.ai/v1  (omit for OpenAI default)
# NEBULA_LLM_MODEL=gpt-4o-mini

# --- Mantle network ---
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_CHAIN_ID=5000

# --- Fund-control policy (deterministic; optional but recommended) ---
# NEBULA_POLICY_MAX_NATIVE_MNT=2.0        # hard cap: block native sends over 2 MNT
# NEBULA_POLICY_AUTO_MAX_NATIVE_MNT=0.1   # auto up to 0.1 MNT; above -> require approval
# NEBULA_POLICY_MAX_SLIPPAGE_BPS=100      # block swaps over 1% slippage
# NEBULA_POLICY_AUTONOMY=auto             # auto | confirm | readonly
# NEBULA_POLICY_TOKEN_ALLOWLIST=0x...,0x...
# NEBULA_POLICY_RECIPIENT_ALLOWLIST=0x...,0x...

# --- Nansen (counterparty intel — powers nansen.labels) ---
# Read-only address-label API; endpoints are credit-metered.
NANSEN_API_KEY=

# --- Bybit (read-only portfolio — powers cex.balance) ---
# Use a ROTATED, READ-ONLY, IP-allowlisted key. Trading/withdrawal stay disabled;
# Nebula never trades on the CEX (that would bypass the on-chain safety pipeline).
BYBIT_API_KEY=
BYBIT_API_SECRET=

# --- Telegram bot channel ---
TELEGRAM_BOT_TOKEN=

# --- Signer (use a secret manager in production; never commit) ---
NEBULA_SIGNER_PRIVATE_KEY=

# Copy to .env and fill in. NEVER commit real secrets — .env is gitignored.

# --- LLM brain (OpenAI-compatible) ---
# Default model is gpt-4o-mini. Point BASE_URL/MODEL at any OpenAI-compatible
# gateway (e.g. Z.AI GLM, Tencent Hunyuan) to switch providers with no code change.
OPENAI_API_KEY=
# NEBULA_LLM_API_KEY=          # alternative to OPENAI_API_KEY
# NEBULA_LLM_BASE_URL=         # e.g. https://api.z.ai/v1  (omit for OpenAI default)
# NEBULA_LLM_MODEL=gpt-4o-mini

# --- Mantle network ---
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_CHAIN_ID=5000

# --- Bybit (CEX module — future integration) ---
# Use a ROTATED, least-privilege, IP-allowlisted key. Withdrawal must stay disabled.
BYBIT_API_KEY=
BYBIT_API_SECRET=

# --- Nansen (onchain analytics / risk — future integration) ---
NANSEN_API_KEY=

# --- Telegram bot channel ---
TELEGRAM_BOT_TOKEN=

# --- Signer (use a secret manager in production; never commit) ---
NEBULA_SIGNER_PRIVATE_KEY=

# Copy to apps/web/.env.local (gitignored) and fill in. Build + runtime read this.

# iron-session signing key — must be at least 32 chars.
# Generate with: openssl rand -hex 32
SESSION_SECRET="replace-with-strong-random-32-plus-char-secret"

# WalletConnect / Reown Cloud projectId — same project the CLI ships with
# (see packages/core/src/operator/walletconnect.ts).
# Not a secret (WC projectIds are public client-side identifiers).
# Add this origin + prod origin to the project allowlist at cloud.reown.com
# or Reown will pop an "origin not on allowlist" modal.
NEXT_PUBLIC_WC_PROJECT_ID="e7667cc8415f283320e0e52b8d5e6e26"

# ─── chat console (server-side agent) ──
# LLM brain for /api/chat. Without it, chat reports "brain not configured".
OPENAI_API_KEY=""
# Optional overrides (defaults: api.openai.com/v1, gpt-4o-mini).
# NEBULA_LLM_BASE_URL=""
# NEBULA_LLM_MODEL="gpt-4o-mini"

# ─── policy cap for value-moving actions ──
# Writes are signed by the USER'S OWN connected wallet (client-side) — the
# server holds NO key. This is just the deterministic per-tx guardrail: nebula
# refuses to prepare a native-MNT action above this many MNT.
NEBULA_POLICY_MAX_NATIVE_MNT="25"
# NEBULA_SIGNER_PRIVATE_KEY is no longer used for the web console (client-signed).
